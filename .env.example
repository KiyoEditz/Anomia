# ===== Backend (src/) =====
PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/anomia?retryWrites=true&w=majority
JWT_SECRET=ganti-dengan-string-acak-panjang
JWT_EXPIRES_IN=7d
DNS_SERVERS=8.8.8.8,1.1.1.1

# ===== Cloudinary =====
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
MODERATION_WEBHOOK_URL=your-moderation-webhook-url

# ===== AWS Rekognition (image moderation, opsional) =====
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1

# ===== CORS (opsional, comma-separated extra origins) =====
# EXTRA_ALLOWED_ORIGINS=https://anomia.example.com

# ===== Bot Detection — Cloudflare Turnstile (opsional) =====
# Ambil key dari: Cloudflare Dashboard → Turnstile → Add Site
# Kalau tidak diisi, Turnstile dilewati (fingerprint & honeypot tetap aktif)
TURNSTILE_SECRET_KEY=

# ===== Frontend (web/) =====
# Tidak perlu .env terpisah. Dev server Vite (port 5173) sudah proxy /api -> http://localhost:3000
# (lihat web/vite.config.js). Ubah di sana kalau backend pakai host/port lain.
# Untuk Turnstile di frontend, buat web/.env dengan:
VITE_TURNSTILE_SITE_KEY=your-site-key
